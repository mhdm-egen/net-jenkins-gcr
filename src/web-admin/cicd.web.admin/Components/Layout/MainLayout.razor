@inherits LayoutComponentBase
@inject JenkinsOptions JenkinsOpts
@inject ThemeService Theme
@implements IDisposable

<MudThemeProvider Theme="@Theme.Current.Theme" IsDarkMode="@Theme.Current.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* App-wide completion toasts: listens to both APIs' SignalR hubs and pops a toast when a
   pipeline run or deployment run finishes, regardless of which page is open. *@
<CompletionToasts />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle menu" />
        <MudText Typo="Typo.h6">Egen/Aven NextGen CI/CD</MudText>
        <MudSpacer />
        <PendingWorkBadge />
        <BuildSyncBadge />
        <JenkinsStatusBadge />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Home</MudNavLink>
            <MudNavGroup Title="Jenkins"
                         Icon="@Icons.Material.Filled.Build"
                         Expanded="true">
                <MudNavLink Href="jenkins/orchestrator"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.AccountTree">
                    Orchestrator
                </MudNavLink>
                <MudNavLink Href="jenkins/pipelines"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.PlayArrow">
                    Pipelines
                </MudNavLink>
                <MudNavLink Href="jenkins/builds"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.History">
                    Builds
                </MudNavLink>
                @* External link to the Jenkins server's own UI — opens in a new tab. *@
                <MudNavLink Href="@JenkinsOpts.BaseUrl"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.OpenInNew">
                    Admin
                </MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Nexus"
                         Icon="@Icons.Material.Filled.Inventory2"
                         Expanded="true">
                <MudNavLink Href="nexus/nuget"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Inventory">
                    Nuget
                </MudNavLink>
                <MudNavLink Href="nexus/docker"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.ViewInAr">
                    Docker
                </MudNavLink>
                @* External link to the Nexus server's own UI — opens in a new tab.
                   Uses the host-reachable URL (localhost) rather than NexusOpts.Url,
                   which is the docker network alias used by the server-side client. *@
                <MudNavLink Href="http://localhost:8081"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.OpenInNew">
                    Admin
                </MudNavLink>
                @* Deep links to Nexus UI browse views (last so they're grouped). *@
                <MudNavLink Href="http://localhost:8081/#browse/browse:nuget-hosted"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Nuget Repo
                </MudNavLink>
                <MudNavLink Href="http://localhost:8081/#browse/browse:docker-private"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Docker Repo
                </MudNavLink>
                <MudNavLink Href="http://localhost:8081/#browse/browse:sboms"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Sbom Repo
                </MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="SCA"
                         Icon="@Icons.Material.Filled.Analytics"
                         Expanded="true">
                <MudNavLink Href="sca/sbom"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.DataObject">
                    SBOM
                </MudNavLink>
                <MudNavLink Href="sca/aspire-sbom"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Inventory2">
                    Aspire SBOM
                </MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="CI"
                         Icon="@Icons.Material.Filled.Hub"
                         Expanded="true">
                <MudNavLink Href="ci/repositories"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Source">
                    Repositories
                </MudNavLink>
                <MudNavLink Href="ci/pipelines"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.AccountTree">
                    Pipelines
                </MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Deployment"
                         Icon="@Icons.Material.Filled.RocketLaunch"
                         Expanded="true">
                <MudNavLink Href="deployment/services" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Apps">Services</MudNavLink>
                <MudNavLink Href="deployment/environments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Public">Environments</MudNavLink>
                <MudNavLink Href="deployment/mappings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Link">Mappings</MudNavLink>
                <MudNavLink Href="deployment/containers" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory2">Inventory</MudNavLink>
                <MudNavLink Href="deployment/aspire-apps" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Hub">Aspire apps</MudNavLink>
                <MudNavLink Href="deployment/previews" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Bolt">Previews</MudNavLink>
                <MudNavLink Href="deployment/runs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">Deployments</MudNavLink>
                <MudNavLink Href="deployment/metrics" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Insights">Metrics</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Kubernetes"
                         Icon="@Icons.Material.Filled.Dns"
                         Expanded="true">
                <MudNavLink Href="kubernetes/cluster" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountTree">Cluster</MudNavLink>
                <MudNavLink Href="kubernetes/apps" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ViewList">Deployed apps</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Cloud"
                         Icon="@Icons.Material.Filled.Cloud"
                         Expanded="true">
                <MudNavLink Href="cloud/azure"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Cloud">
                    Azure
                </MudNavLink>
                <MudNavGroup Title="Google"
                             Icon="@Icons.Material.Filled.Cloud"
                             Expanded="true">
                    <MudNavLink Href="cloud/google"
                                Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Dashboard">
                        Overview
                    </MudNavLink>
                    <MudNavLink Href="cloud/google/artifacts"
                                Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.Inventory2">
                        Artifacts
                    </MudNavLink>
                    <MudNavLink Href="cloud/google/cloud-run"
                                Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.PlayCircleOutline">
                        Cloud Run
                    </MudNavLink>
                </MudNavGroup>
            </MudNavGroup>
            <MudDivider Class="my-2" />
            <MudNavLink Href="settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @* MaxWidth.False removes the 1280px cap so panels grow with the viewport;
           the inline min-width keeps a horizontal scrollbar at the page level
           instead of cramping panels on narrow windows. *@
        <MudContainer MaxWidth="MaxWidth.False" Class="my-4" Style="min-width: 600px;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    // The theme lives in ThemeService (shared with the Settings page). Re-render the app-wide provider when it
    // changes — from either the Settings selector or the initial localStorage load.
    protected override void OnInitialized() => Theme.Changed += OnThemeChanged;

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await Theme.InitializeAsync(); // localStorage is only available post-render
    }

    public void Dispose() => Theme.Changed -= OnThemeChanged;
}
