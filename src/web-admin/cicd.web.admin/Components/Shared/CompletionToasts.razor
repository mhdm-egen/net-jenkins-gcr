@implements IDisposable
@inject RunEventsService Events
@inject ISnackbar Snackbar
@inject NavigationManager Nav

@* Headless, app-wide listener. Hosted once in MainLayout so it lives for the whole Blazor Server circuit.
   It owns nothing — it starts the shared RunEventsService and toasts on its completion events. *@

@code {
    protected override void OnInitialized()
    {
        Events.PipelineRunCompleted += OnPipelineRunCompleted;
        Events.DeploymentRunCompleted += OnDeploymentRunCompleted;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await Events.EnsureStartedAsync(); // start the hubs once the circuit is interactive
    }

    private void OnPipelineRunCompleted(PipelineRunCompletedMsg m) => InvokeAsync(() =>
    {
        var text = $"Pipeline '{m.PipelineName}' {m.Status.ToLowerInvariant()}";
        if (m.Status != "Succeeded" && m.FailureReason is { Length: > 0 } reason) text += $" — {reason}";
        Toast(text, m.Status, "/jenkins/runs");
    });

    private void OnDeploymentRunCompleted(DeploymentRunCompletedMsg m) => InvokeAsync(() =>
        Toast(m.Detail is { Length: > 0 } d ? $"{m.Title} — {d}" : m.Title, m.Status, "/deployment/runs"));

    private void Toast(string text, string status, string href)
    {
        var severity = status switch
        {
            "Succeeded" => Severity.Success,
            "Cancelled" => Severity.Warning,
            _ => Severity.Error,
        };
        Snackbar.Add(text, severity, cfg =>
        {
            cfg.RequireInteraction = severity == Severity.Error; // failures persist until dismissed
            cfg.OnClick = _ => { Nav.NavigateTo(href); return Task.CompletedTask; };
        });
    }

    public void Dispose()
    {
        Events.PipelineRunCompleted -= OnPipelineRunCompleted;
        Events.DeploymentRunCompleted -= OnDeploymentRunCompleted;
    }
}
