@page "/publisher/promotions"
@inject PublisherApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Publisher — Promotions</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Promotions</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        history of pushes from local Nexus to remote registries
    </MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_items is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No promotions yet. They appear here when a rule fires or you promote a container manually.
        </MudText>
    }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="PromotionDto">
            <HeaderContent>
                <MudTh Style="width: 7rem;">Status</MudTh>
                <MudTh>Container</MudTh>
                <MudTh>Remote ref</MudTh>
                <MudTh>Registry</MudTh>
                <MudTh>Trigger</MudTh>
                <MudTh Style="width: 11rem;">Requested</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
                </MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.ContainerName @context.Version</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.8em;">
                    @context.RemoteRef
                    @if (context.Status == PromotionStatusDto.Failed && !string.IsNullOrEmpty(context.FailureReason))
                    {
                        <MudTooltip Text="@context.FailureReason"><MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Small" /></MudTooltip>
                    }
                </MudTd>
                <MudTd>@context.RegistryName</MudTd>
                <MudTd Style="font-size: 0.85em;">@context.TriggeredBy</MudTd>
                <MudTd>@context.RequestedAtUtc.LocalDateTime.ToString("g")</MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<PromotionDto>? _items;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try { _items = await Api.ListPromotionsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private static Color StatusColor(PromotionStatusDto s) => s switch
    {
        PromotionStatusDto.Succeeded => Color.Success,
        PromotionStatusDto.Failed => Color.Error,
        PromotionStatusDto.Pending => Color.Info,
        _ => Color.Default,
    };
}
