@page "/publisher/rules"
@inject PublisherApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Publisher — Rules</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Automation rules</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        when a container is published, optionally push it to a remote registry
    </MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate" Disabled="@(_registries is null or { Count: 0 })">
        Add rule
    </MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}
@if (_registries is { Count: 0 })
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">
        No registries configured yet — add one on the <MudLink Href="/publisher/registries">Registries</MudLink> page before creating a rule.
    </MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_items is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No rules yet. Nothing is pushed automatically until you add an enabled rule.
        </MudText>
    }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="AutomationRuleDto">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>When</MudTh>
                <MudTh>Filter</MudTh>
                <MudTh>Target</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 9rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Trigger → @context.Action</MudChip></MudTd>
                <MudTd Style="font-size: 0.85em;">@FilterText(context)</MudTd>
                <MudTd>@RegistryName(context.TargetRegistryId)</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.Enabled ? Color.Success : Color.Default)" Variant="Variant.Filled">
                        @(context.Enabled ? "Enabled" : "Disabled")
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                    </MudTooltip>
                    <MudTooltip Text="@(context.Enabled ? "Disable" : "Enable")">
                        <MudIconButton Size="Size.Small"
                                       Icon="@(context.Enabled ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                       Color="@(context.Enabled ? Color.Success : Color.Default)"
                                       OnClick="@(() => ToggleAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudDialog @bind-Visible="_show" Options="_dialogOptions">
    <TitleContent>@(_editingId is null ? "Add rule" : "Edit rule")</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_form.Name" Label="Name" Required="true" Disabled="@(_editingId is not null)" />
        <MudSelect @bind-Value="_form.TargetRegistryId" Label="Push to registry" T="Guid" Required="true">
            @foreach (var r in _registries ?? new List<RemoteRegistryDto>())
            {
                <MudSelectItem Value="@r.Id">@r.Name (@r.RegistryHost)</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_form.ContainerNamePattern" Label="Container name pattern"
                      HelperText="Glob, e.g. web-* or egen/*. Empty = any container." />
        <MudTextField @bind-Value="_repositoryIdText" Label="Source repository id (optional GUID)"
                      HelperText="Restrict to one CI source repo. Empty = any." />
        <MudSwitch T="bool" @bind-Value="_form.RequirePublishable" Color="Color.Primary"
                   Label="Only if tagged publishable (channel)" Class="mt-2" />
        @if (_form.RequirePublishable)
        {
            <MudTextField @bind-Value="_form.RequiredChannelName" Label="Required channel (optional)"
                          HelperText="Empty = any channel satisfies the requirement." />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _show = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_busy">
            @(_editingId is null ? "Add" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<AutomationRuleDto>? _items;
    private IReadOnlyList<RemoteRegistryDto>? _registries;
    private bool _loading, _busy;
    private string? _error;

    private static readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private bool _show;
    private Guid? _editingId;
    private Form _form = new();
    private string _repositoryIdText = "";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            _registries = await Api.ListRegistriesAsync();
            _items = await Api.ListRulesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private string RegistryName(Guid id) => _registries?.FirstOrDefault(r => r.Id == id)?.Name ?? id.ToString();

    private static string FilterText(AutomationRuleDto r)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(r.ContainerNamePattern)) parts.Add($"name={r.ContainerNamePattern}");
        if (r.RepositoryId is { } rid) parts.Add($"repo={rid.ToString()[..8]}…");
        if (r.RequirePublishable) parts.Add(string.IsNullOrEmpty(r.RequiredChannelName) ? "publishable" : $"channel={r.RequiredChannelName}");
        return parts.Count == 0 ? "any container" : string.Join(", ", parts);
    }

    private void OpenCreate()
    {
        _editingId = null;
        _form = new Form { TargetRegistryId = _registries?.FirstOrDefault()?.Id ?? Guid.Empty };
        _repositoryIdText = "";
        _show = true;
    }

    private void OpenEdit(AutomationRuleDto r)
    {
        _editingId = r.Id;
        _form = new Form
        {
            Name = r.Name,
            TargetRegistryId = r.TargetRegistryId,
            ContainerNamePattern = r.ContainerNamePattern ?? "",
            RequirePublishable = r.RequirePublishable,
            RequiredChannelName = r.RequiredChannelName ?? "",
        };
        _repositoryIdText = r.RepositoryId?.ToString() ?? "";
        _show = true;
    }

    private async Task SaveAsync()
    {
        Guid? repoId = null;
        if (!string.IsNullOrWhiteSpace(_repositoryIdText))
        {
            if (!Guid.TryParse(_repositoryIdText.Trim(), out var parsed)) { Snackbar.Add("Repository id must be a valid GUID.", Severity.Warning); return; }
            repoId = parsed;
        }

        _busy = true;
        try
        {
            var pattern = string.IsNullOrWhiteSpace(_form.ContainerNamePattern) ? null : _form.ContainerNamePattern;
            var channel = string.IsNullOrWhiteSpace(_form.RequiredChannelName) ? null : _form.RequiredChannelName;
            if (_editingId is { } id)
            {
                await Api.UpdateRuleAsync(id, new UpdateRuleRequest(
                    RuleTriggerDto.ContainerPublished, RuleActionDto.PushToRemote, _form.TargetRegistryId,
                    repoId, pattern, _form.RequirePublishable, channel));
                Snackbar.Add($"Updated '{_form.Name}'.", Severity.Success);
            }
            else
            {
                await Api.CreateRuleAsync(new CreateRuleRequest(
                    _form.Name, RuleTriggerDto.ContainerPublished, RuleActionDto.PushToRemote, _form.TargetRegistryId,
                    repoId, pattern, _form.RequirePublishable, channel));
                Snackbar.Add($"Added '{_form.Name}'.", Severity.Success);
            }
            _show = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ToggleAsync(AutomationRuleDto r)
    {
        try
        {
            if (r.Enabled) await Api.DisableRuleAsync(r.Id); else await Api.EnableRuleAsync(r.Id);
            Snackbar.Add($"{(r.Enabled ? "Disabled" : "Enabled")} '{r.Name}'.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteAsync(AutomationRuleDto r)
    {
        try { await Api.DeleteRuleAsync(r.Id); Snackbar.Add($"Deleted '{r.Name}'.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private sealed class Form
    {
        public string Name { get; set; } = "";
        public Guid TargetRegistryId { get; set; } = Guid.Empty;
        public string ContainerNamePattern { get; set; } = "";
        public bool RequirePublishable { get; set; }
        public string RequiredChannelName { get; set; } = "";
    }
}
