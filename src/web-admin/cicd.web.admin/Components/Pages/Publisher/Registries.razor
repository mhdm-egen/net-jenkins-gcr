@page "/publisher/registries"
@inject PublisherApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Publisher — Registries</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Remote registries</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        push targets for promoting containers out of local Nexus
    </MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">
        Add registry
    </MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_items is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No registries configured. Click <strong>Add registry</strong> — the default is Google Artifact Registry with ADC auth (no secret).
        </MudText>
    }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="RemoteRegistryDto">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Provider</MudTh>
                <MudTh>Host / path</MudTh>
                <MudTh Style="width: 10rem;">Auth</MudTh>
                <MudTh Style="width: 6rem;">Default</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 12rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Provider</MudChip></MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.RegistryHost/@context.RepositoryPath</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.AuthMethod</MudChip>
                    @if (context.AuthMethod != RegistryAuthMethodDto.Adc && !string.IsNullOrEmpty(context.CredentialSecretRef))
                    {
                        <MudTooltip Text="@($"secret ref: {context.CredentialSecretRef}")"><MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Small" /></MudTooltip>
                    }
                </MudTd>
                <MudTd>
                    @if (context.IsDefault)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">default</MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.Enabled ? Color.Success : Color.Default)" Variant="Variant.Filled">
                        @(context.Enabled ? "Enabled" : "Disabled")
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    @if (!context.IsDefault)
                    {
                        <MudTooltip Text="Make default">
                            <MudIconButton Icon="@Icons.Material.Filled.Star" Size="Size.Small" OnClick="@(() => SetDefaultAsync(context))" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                    </MudTooltip>
                    <MudTooltip Text="@(context.Enabled ? "Disable" : "Enable")">
                        <MudIconButton Size="Size.Small"
                                       Icon="@(context.Enabled ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                       Color="@(context.Enabled ? Color.Success : Color.Default)"
                                       OnClick="@(() => ToggleAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudDialog @bind-Visible="_show" Options="_dialogOptions">
    <TitleContent>@(_editingId is null ? "Add registry" : "Edit registry")</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_form.Name" Label="Name" Required="true" Disabled="@(_editingId is not null)"
                      HelperText="Unique handle, e.g. gar-prod" />
        <MudSelect @bind-Value="_form.Provider" Label="Provider" T="RegistryProviderDto">
            @foreach (var p in Enum.GetValues<RegistryProviderDto>())
            {
                <MudSelectItem Value="@p">@p</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_form.RegistryHost" Label="Registry host" Required="true"
                      HelperText="e.g. us-docker.pkg.dev" />
        <MudTextField @bind-Value="_form.RepositoryPath" Label="Repository path"
                      HelperText="e.g. my-project/my-repo" />
        <MudSelect @bind-Value="_form.AuthMethod" Label="Auth method" T="RegistryAuthMethodDto">
            @foreach (var a in Enum.GetValues<RegistryAuthMethodDto>())
            {
                <MudSelectItem Value="@a">@a</MudSelectItem>
            }
        </MudSelect>
        @if (_form.AuthMethod == RegistryAuthMethodDto.UsernamePassword)
        {
            <MudTextField @bind-Value="_form.Username" Label="Username" Required="true" />
        }
        @if (_form.AuthMethod != RegistryAuthMethodDto.Adc)
        {
            <MudTextField @bind-Value="_form.CredentialSecretRef" Label="Credential secret reference" Required="true"
                          HelperText="A NAME resolved at push time (e.g. Publisher__Registries__gar-prod__Key) — never the secret itself" />
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Text" Class="mt-2">
                ADC uses ambient credentials (Workload Identity / gcloud) — no secret stored.
            </MudAlert>
        }
        @if (_editingId is null)
        {
            <MudSwitch T="bool" @bind-Value="_form.MakeDefault" Color="Color.Primary" Label="Make default target" Class="mt-2" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _show = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_busy">
            @(_editingId is null ? "Add" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<RemoteRegistryDto>? _items;
    private bool _loading, _busy;
    private string? _error;

    private static readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private bool _show;
    private Guid? _editingId;
    private Form _form = new();

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try { _items = await Api.ListRegistriesAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private void OpenCreate()
    {
        _editingId = null;
        _form = new Form();
        _show = true;
    }

    private void OpenEdit(RemoteRegistryDto r)
    {
        _editingId = r.Id;
        _form = new Form
        {
            Name = r.Name,
            Provider = r.Provider,
            RegistryHost = r.RegistryHost,
            RepositoryPath = r.RepositoryPath,
            AuthMethod = r.AuthMethod,
            Username = r.Username ?? "",
            CredentialSecretRef = r.CredentialSecretRef ?? "",
        };
        _show = true;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            var user = string.IsNullOrWhiteSpace(_form.Username) ? null : _form.Username;
            var secret = string.IsNullOrWhiteSpace(_form.CredentialSecretRef) ? null : _form.CredentialSecretRef;
            if (_editingId is { } id)
            {
                await Api.UpdateRegistryAsync(id, new UpdateRegistryRequest(
                    _form.Provider, _form.RegistryHost, _form.RepositoryPath, _form.AuthMethod, user, secret));
                Snackbar.Add($"Updated '{_form.Name}'.", Severity.Success);
            }
            else
            {
                await Api.CreateRegistryAsync(new CreateRegistryRequest(
                    _form.Name, _form.Provider, _form.RegistryHost, _form.RepositoryPath,
                    _form.AuthMethod, user, secret, _form.MakeDefault));
                Snackbar.Add($"Added '{_form.Name}'.", Severity.Success);
            }
            _show = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task SetDefaultAsync(RemoteRegistryDto r)
    {
        try { await Api.SetDefaultRegistryAsync(r.Id); Snackbar.Add($"'{r.Name}' is now the default.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task ToggleAsync(RemoteRegistryDto r)
    {
        try
        {
            if (r.Enabled) await Api.DisableRegistryAsync(r.Id); else await Api.EnableRegistryAsync(r.Id);
            Snackbar.Add($"{(r.Enabled ? "Disabled" : "Enabled")} '{r.Name}'.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteAsync(RemoteRegistryDto r)
    {
        try { await Api.DeleteRegistryAsync(r.Id); Snackbar.Add($"Deleted '{r.Name}'.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private sealed class Form
    {
        public string Name { get; set; } = "";
        public RegistryProviderDto Provider { get; set; } = RegistryProviderDto.GoogleArtifactRegistry;
        public string RegistryHost { get; set; } = "us-docker.pkg.dev";
        public string RepositoryPath { get; set; } = "";
        public RegistryAuthMethodDto AuthMethod { get; set; } = RegistryAuthMethodDto.Adc;
        public string Username { get; set; } = "";
        public string CredentialSecretRef { get; set; } = "";
        public bool MakeDefault { get; set; }
    }
}
