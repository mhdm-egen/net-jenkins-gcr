@page "/settings"
@inject ThemeService Theme

<PageTitle>Settings</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Settings</MudText>
    <MudSpacer />
</MudStack>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Palette" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Appearance</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
        Choose a theme. Applies across the whole app and is remembered on this browser.
    </MudText>
    <div style="max-width: 20rem;">
        <ThemeSwitcher CurrentThemeId="@Theme.Current.Id" ThemeChanged="@(id => Theme.SetAsync(id))" />
    </div>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Build history</MudText>
        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled">Live</MudChip>
    </MudStack>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        The Builds / BuildDetails pages read directly from Jenkins. Persisted build
        history, artifact provenance, and deployment handoffs are now owned by the
        Jenkins CI service — see the <MudLink Href="ci/repositories">CI</MudLink>
        section. The old local SQLite build mirror has been retired.
    </MudText>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 3px solid var(--mud-palette-primary);">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Demo setup</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
        Install curated demo configuration — tracked repos, services, environments, mappings, and Aspire apps
        for the built-in demo scenarios (Aspire auto-deploy, blue-green / canary, Cloud Run, k8s admin) — so you
        can trigger real builds and deploys. Additive and idempotent; creates no runs.
    </MudText>
    <MudButton Href="/settings/demo" Color="Color.Primary" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.AutoAwesome">Open demo setup</MudButton>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 3px solid var(--mud-palette-error);">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
        <MudText Typo="Typo.h6">Danger zone</MudText>
    </MudStack>
    <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
        Individually selectable resets — wipe deployment/aspire runs, previews, Jenkins build history, and Nexus
        artifacts (NuGet / Docker / SBOMs) back to a clean slate. Configuration (pipelines, repositories, services,
        environments, mappings, Aspire apps) is always kept.
    </MudText>
    <MudButton Href="/settings/reset" Color="Color.Error" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.DeleteForever">Open reset tools</MudButton>
</MudPaper>
