@*
    Publish-a-release form. For Service units, the user picks an ArtifactType
    (Zip/ContainerImage/NuGet) and provides an ArtifactUri. For Application
    units, ArtifactType is forced to Manifest and ArtifactUri is hidden.
*@
@inject DeploymentApiClient Api

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudTextField @bind-Value="_semver"
                          Label="Semantic version"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="e.g. 1.2.3" />
            <MudTextField @bind-Value="_buildNumber"
                          Label="Build number"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="e.g. cicd-build/#42" />
            <MudTextField @bind-Value="_commitSha"
                          Label="Commit SHA"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="Full git SHA — e.g. abc123def456…" />

            @if (UnitIsApplication)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Application releases are manifest-only (BOM). Add member compositions
                    on the release detail page after publishing.
                </MudAlert>
            }
            else
            {
                <MudSelect T="ArtifactTypeDto"
                           @bind-Value="_artifactType"
                           Label="Artifact type"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@ArtifactTypeDto.ContainerImage">Container Image</MudSelectItem>
                    <MudSelectItem Value="@ArtifactTypeDto.NuGet">NuGet</MudSelectItem>
                    <MudSelectItem Value="@ArtifactTypeDto.Zip">Zip</MudSelectItem>
                </MudSelect>

                @if (_artifactType == ArtifactTypeDto.ContainerImage && _images.Count > 0)
                {
                    <MudSelect T="Guid?" Value="_selectedImageId" ValueChanged="OnImageSelectedAsync"
                               Label="From catalog (optional)" Variant="Variant.Outlined" Clearable="true"
                               HelperText="Pick a coordinate to resolve a tag to an immutable digest">
                        @foreach (var img in _images)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)img.Id)">@img.BaseRef</MudSelectItem>
                        }
                    </MudSelect>
                    @if (_selectedImageId is not null)
                    {
                        <MudSelect T="string" Value="_selectedTag" ValueChanged="OnTagSelectedAsync"
                                   Label="Tag" Variant="Variant.Outlined" Disabled="@(_tags.Count == 0)">
                            @foreach (var t in _tags)
                            {
                                <MudSelectItem T="string" Value="@t">@t</MudSelectItem>
                            }
                        </MudSelect>
                        @if (_resolving)
                        {
                            <MudProgressLinear Indeterminate="true" />
                        }
                        else if (_resolveError is { Length: > 0 })
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@_resolveError</MudAlert>
                        }
                    }
                }

                <MudTextField @bind-Value="_artifactUri"
                              Label="Artifact URI"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="500"
                              HelperText="@UriHint" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.NewReleases"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Publish
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool UnitIsApplication { get; set; }
    [Parameter] public string UnitName { get; set; } = "";

    private string _semver = "";
    private string _buildNumber = "";
    private string _commitSha = "";
    private ArtifactTypeDto _artifactType = ArtifactTypeDto.ContainerImage;
    private string _artifactUri = "";

    // Container-image catalog picker: select a coordinate, pick a (live-discovered)
    // tag, resolve it to an immutable digest ref that fills the Artifact URI.
    private IReadOnlyList<ContainerImageDto> _images = Array.Empty<ContainerImageDto>();
    private Guid? _selectedImageId;
    private IReadOnlyList<string> _tags = Array.Empty<string>();
    private string? _selectedTag;
    private bool _resolving;
    private string? _resolveError;

    protected override async Task OnInitializedAsync()
    {
        if (UnitIsApplication) return;
        try { _images = await Api.ListContainerImagesAsync(onlyActive: true); }
        catch { _images = Array.Empty<ContainerImageDto>(); }
    }

    private async Task OnImageSelectedAsync(Guid? id)
    {
        _selectedImageId = id;
        _selectedTag = null;
        _tags = Array.Empty<string>();
        _resolveError = null;
        if (id is not { } imageId) return;
        var img = _images.FirstOrDefault(i => i.Id == imageId);
        if (img is null) return;

        try { _tags = await Api.ListContainerImageTagsAsync(img.Registry, img.Repository, img.Name); }
        catch { _tags = Array.Empty<string>(); }

        var initial = _tags.Contains(img.DefaultTag) ? img.DefaultTag : _tags.FirstOrDefault();
        if (initial is not null) await OnTagSelectedAsync(initial);
        else _resolveError = "No tags found in the registry for this image.";
        StateHasChanged();
    }

    private async Task OnTagSelectedAsync(string tag)
    {
        _selectedTag = tag;
        var img = _images.FirstOrDefault(i => i.Id == _selectedImageId);
        if (img is null) return;

        _resolving = true; _resolveError = null; StateHasChanged();
        try
        {
            var res = await Api.ResolveContainerImageAsync(img.Registry, img.Repository, img.Name, tag);
            if (res is null) _resolveError = $"Tag '{tag}' not found in the registry.";
            else _artifactUri = res.DigestRef;
        }
        catch (Exception ex) { _resolveError = ex.Message; }
        finally { _resolving = false; StateHasChanged(); }
    }

    private string UriHint => _artifactType switch
    {
        ArtifactTypeDto.ContainerImage => "e.g. registry.example.com/billing-api:1.2.3",
        ArtifactTypeDto.NuGet => "e.g. https://nexus/repository/nuget-hosted/billing.contracts/1.2.3",
        ArtifactTypeDto.Zip => "e.g. https://nexus/repository/raw/billing-api-1.2.3.zip",
        _ => "",
    };

    private bool CanSubmit()
    {
        if (string.IsNullOrWhiteSpace(_semver)) return false;
        if (string.IsNullOrWhiteSpace(_buildNumber)) return false;
        if (string.IsNullOrWhiteSpace(_commitSha)) return false;
        if (!UnitIsApplication && string.IsNullOrWhiteSpace(_artifactUri)) return false;
        return true;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var type = UnitIsApplication ? ArtifactTypeDto.Manifest : _artifactType;
        var uri = UnitIsApplication ? null : _artifactUri.Trim();
        MudDialog.Close(DialogResult.Ok(new Result(
            _semver.Trim(), _buildNumber.Trim(), _commitSha.Trim(), type, uri)));
    }

    public sealed record Result(
        string SemanticVersion,
        string BuildNumber,
        string CommitSha,
        ArtifactTypeDto ArtifactType,
        string? ArtifactUri);
}
