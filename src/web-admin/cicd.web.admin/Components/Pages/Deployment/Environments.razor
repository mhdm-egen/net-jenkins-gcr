@page "/deployment/environments"
@inject DeploymentApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Deployment — Environments</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Environments</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">deploy targets — Cloud Run (GCP) and/or Kubernetes (context + namespace)</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add environment</MudButton>
</MudStack>

@if (_error is { Length: > 0 }) { <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert> }

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null) { <MudProgressLinear Indeterminate="true" /> }
    else if (_items is { Count: 0 }) { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No environments yet.</MudText> }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="EnvironmentDto">
            <HeaderContent><MudTh>Name</MudTh><MudTh>GCP project</MudTh><MudTh>Region</MudTh><MudTh>GAR repo</MudTh><MudTh>Kubernetes</MudTh><MudTh>Protected</MudTh><MudTh Style="width:9rem; text-align:right;"></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.85em;">@context.GcpProject</MudTd>
                <MudTd>@context.Region</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.85em;">@context.GarRepository</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.8em;">@(string.IsNullOrEmpty(context.KubernetesContext) ? "—" : $"{context.KubernetesContext} / {context.KubernetesNamespace}")</MudTd>
                <MudTd>
                    @if (context.IsProtected)
                    { <MudTooltip Text="Deploys to this environment require approval"><MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Shield">Approval</MudChip></MudTooltip> }
                    else { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">—</MudText> }
                </MudTd>
                <MudTd Style="text-align:right;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEdit(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudDialog @bind-Visible="_show" Options="_dlg">
    <TitleContent>@(_editingId is null ? "Add environment" : "Edit environment")</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_form.Name" Label="Name" Required="true" HelperText="e.g. dev, staging, prod" />
        <MudText Typo="Typo.subtitle2" Class="mt-2">Cloud Run target (optional)</MudText>
        <MudTextField @bind-Value="_form.GcpProject" Label="GCP project" />
        <MudTextField @bind-Value="_form.Region" Label="Region" HelperText="e.g. us-central1" />
        <MudTextField @bind-Value="_form.GarRepository" Label="GAR repository" HelperText="Artifact Registry repo name" />
        <MudText Typo="Typo.subtitle2" Class="mt-3">Kubernetes target (optional)</MudText>
        <MudTextField @bind-Value="_form.KubernetesContext" Label="Kube context" HelperText="e.g. docker-desktop" />
        <MudTextField @bind-Value="_form.KubernetesNamespace" Label="Namespace" />
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Provide a Cloud Run target and/or a Kubernetes target.</MudText>
        <MudDivider Class="my-3" />
        <MudSwitch @bind-Value="_form.IsProtected" Color="Color.Warning" Label="Protected — require approval before any deploy" />
        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">When on, every deploy targeting this environment (manual, promotion, rollback, or auto-deploy) parks as Awaiting approval until someone approves it.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _show = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_busy">@(_editingId is null ? "Add" : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<EnvironmentDto>? _items;
    private bool _loading, _busy, _show;
    private string? _error;
    private Guid? _editingId;
    private Form _form = new();
    private static readonly DialogOptions _dlg = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try { _items = await Api.ListEnvironmentsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private void OpenCreate() { _editingId = null; _form = new Form(); _show = true; }
    private void OpenEdit(EnvironmentDto e) { _editingId = e.Id; _form = new Form { Name = e.Name, GcpProject = e.GcpProject, Region = e.Region, GarRepository = e.GarRepository, KubernetesContext = e.KubernetesContext ?? "", KubernetesNamespace = e.KubernetesNamespace ?? "", IsProtected = e.IsProtected }; _show = true; }

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            if (_editingId is { } id) { await Api.UpdateEnvironmentAsync(id, new UpdateEnvironmentRequest(_form.Name, _form.GcpProject, _form.Region, _form.GarRepository, _form.KubernetesContext, _form.KubernetesNamespace, _form.IsProtected)); Snackbar.Add("Saved.", Severity.Success); }
            else { await Api.CreateEnvironmentAsync(new CreateEnvironmentRequest(_form.Name, _form.GcpProject, _form.Region, _form.GarRepository, _form.KubernetesContext, _form.KubernetesNamespace, _form.IsProtected)); Snackbar.Add("Added.", Severity.Success); }
            _show = false; await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(EnvironmentDto e)
    {
        try { await Api.DeleteEnvironmentAsync(e.Id); Snackbar.Add($"Deleted '{e.Name}'.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private sealed class Form { public string Name { get; set; } = ""; public string GcpProject { get; set; } = ""; public string Region { get; set; } = ""; public string GarRepository { get; set; } = ""; public string KubernetesContext { get; set; } = ""; public string KubernetesNamespace { get; set; } = ""; public bool IsProtected { get; set; } }
}
