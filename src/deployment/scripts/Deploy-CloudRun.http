# Deploy a container to Google Cloud Run via the Deployment API.
#
# REST Client (.http) companion to Deploy-CloudRun.ps1. Run the requests top to
# bottom — each named request feeds its id into the next via {{name.response.*}}.
# Works in VS Code "REST Client" and the Visual Studio / Rider .http runner.
#
# Auth & the target Cloud Run service: the API talks to Cloud Run with ADC
# (GOOGLE_APPLICATION_CREDENTIALS / Workload Identity) and the service named by
# {{resourceId}} must already exist — the adapter updates it in place.

@host = http://localhost:9601

# --- Edit these for your deployment -----------------------------------------
@serviceName     = orders-api
@serviceKind     = 0
@repositoryUrl   = https://example.com/orders-api.git
@targetFramework = net10.0

@gcpProject      = my-proj
@region          = us-central1
@cloudRunService = orders-api
@resourceId      = projects/{{gcpProject}}/locations/{{region}}/services/{{cloudRunService}}

@image           = us-docker.pkg.dev/my-proj/repo/orders-api@sha256:abc123...
@semanticVersion = 1.4.0
@buildNumber     = 42
@commitSha       = abc1234

@environmentName = Development
@promotionRank   = 1
@requiresApproval = false
@isProduction    = false

@strategy        = 0
@trigger         = 1
@triggeredBy     = deploy-script@heydt.org
@approver        = mike@heydt.org
# Enum cheat-sheet:
#   ServiceKind   0=WebApi 1=Mvc 2=WorkerService 3=AzureFunction 4=Console 5=Other
#   ArtifactType  0=Manifest 1=Zip 2=ContainerImage 3=NuGet
#   TargetKind    0=IIS 1=AzureAppService 2=KubernetesCluster 3=ContainerApp 4=VM 5=GoogleCloudRun
#   Strategy      0=Direct 1=BlueGreen 2=Canary 3=Rolling   (Direct only in v1)
#   Trigger       0=Manual 1=Pipeline 2=AutoPromote
#   Verdict       0=Pending 1=Approved 2=Rejected
# ----------------------------------------------------------------------------

### 1. Register the service (deployable unit). Returns a ServiceDto; id is in the body.
# @name service
POST {{host}}/api/deployment/services
Content-Type: application/json

{
  "name": "{{serviceName}}",
  "kind": {{serviceKind}},
  "repositoryUrl": "{{repositoryUrl}}",
  "targetFramework": "{{targetFramework}}"
}

###
@serviceId = {{service.response.body.id}}

### 2. Register the environment.
# @name environment
POST {{host}}/api/deployment/environments
Content-Type: application/json

{
  "name": "{{environmentName}}",
  "promotionRank": {{promotionRank}},
  "requiresApproval": {{requiresApproval}},
  "isProduction": {{isProduction}}
}

###
@environmentId = {{environment.response.body.id}}

### 3. Add the Cloud Run target to that environment (TargetKind=5). Body returns { "id": ... }.
# @name target
POST {{host}}/api/deployment/environments/{{environmentId}}/targets
Content-Type: application/json

{
  "targetKind": 5,
  "resourceId": "{{resourceId}}",
  "region": "{{region}}",
  "slot": null
}

###
@targetId = {{target.response.body.id}}

### 4. Publish the container release (ArtifactType=2 ContainerImage). Body returns { "id": ... }.
# @name release
POST {{host}}/api/deployment/releases
Content-Type: application/json

{
  "deployableUnitId": "{{serviceId}}",
  "semanticVersion": "{{semanticVersion}}",
  "buildNumber": "{{buildNumber}}",
  "commitSha": "{{commitSha}}",
  "artifactType": 2,
  "artifactUri": "{{image}}"
}

###
@releaseId = {{release.response.body.id}}

### 5. Start the deployment. Returns { parentDeploymentId, childDeploymentIds[] }.
# @name start
POST {{host}}/api/deployment/deployments
Content-Type: application/json

{
  "releaseId": "{{releaseId}}",
  "environmentId": "{{environmentId}}",
  "targetIds": ["{{targetId}}"],
  "strategy": {{strategy}},
  "trigger": {{trigger}},
  "triggeredByPrincipal": "{{triggeredBy}}",
  "skipPromotionPathReason": null,
  "overrideFreezeReason": null
}

###
@deploymentId = {{start.response.body.parentDeploymentId}}

### 6. Poll the deployment (re-send until head.status is terminal: 2=Succeeded 3=Failed 4=RolledBack 5=Cancelled).
# @name detail
GET {{host}}/api/deployment/deployments/{{deploymentId}}

### 6a. (Only if the environment RequiresApproval) Approve it.
#   - approvalId comes from {{detail.response.body.approvals[0].id}} above.
#   - approverPrincipal MUST differ from triggeredBy (4-eyes rule).
POST {{host}}/api/deployment/deployments/{{deploymentId}}/approve
Content-Type: application/json

{
  "approvalId": "{{detail.response.body.approvals[0].id}}",
  "approverPrincipal": "{{approver}}",
  "verdict": 1,
  "comment": "Approved via Deploy-CloudRun.http"
}

### 6b. (Optional) Cancel instead of approving.
POST {{host}}/api/deployment/deployments/{{deploymentId}}/cancel
Content-Type: application/json

{ "cancellationReason": "Cancelled via Deploy-CloudRun.http" }

### 7. Verify: effective running version per (service, target) in the environment (Q1').
GET {{host}}/api/deployment/dashboards/effective-versions?applicationId={{serviceId}}&environmentId={{environmentId}}

###
