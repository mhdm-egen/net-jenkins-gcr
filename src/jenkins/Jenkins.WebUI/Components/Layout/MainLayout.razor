@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudThemeProvider Theme="@_active.Theme" IsDarkMode="@_active.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle menu" />
        <MudText Typo="Typo.h6">Jenkins WebUI</MudText>
        <MudSpacer />
        <ThemeSwitcher CurrentThemeId="@_active.Id" ThemeChanged="OnThemeChangedAsync" />
        <JenkinsStatusBadge />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href=""
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.AccountTree">
                Pipeline
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string LocalStorageKey = "jenkins-webui-theme";

    private bool _drawerOpen = true;
    private AppThemes.Entry _active = AppThemes.Resolve(AppThemes.SolarizedDarkId);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Persisted theme lives in localStorage; read it once on first interactive render.
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageKey);
            var resolved = AppThemes.Resolve(stored);
            if (resolved.Id != _active.Id)
            {
                _active = resolved;
                StateHasChanged();
            }
        }
        catch (JSDisconnectedException) { /* page tearing down */ }
    }

    private async Task OnThemeChangedAsync(string themeId)
    {
        _active = AppThemes.Resolve(themeId);
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, _active.Id);
        }
        catch (JSDisconnectedException) { /* page tearing down */ }
        StateHasChanged();
    }
}
