{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "JenkinsCi": "Data Source=jenkins-ci.db"
  },
  "Deployment": {
    "ApiBaseUrl": "http://localhost:9601"
  },
  "Jenkins": {
    "Url": "http://jenkins:8080",
    "User": "admin",
    "ApiToken": "",
    "Sync": {
      "Enabled": true,
      "PollIntervalSeconds": 30,
      "BackfillCount": 25,
      "PerJobFetchCount": 10
    }
  }
}
