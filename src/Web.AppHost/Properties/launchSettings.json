{
  "$schema": "https://json.schemastore.org/launchsettings.json",
    "profiles": {
      "http": {
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "applicationUrl": "http://localhost:5156",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      },
      "https": {
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "applicationUrl": "https://localhost:7000;http://localhost:5156",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        },
        "launchUrl": "weather"
      },
      "Docker": {
        "commandName": "Executable",
        "executablePath": "docker",
        "commandLineArgs": "run --rm -p 8080:8080 -e ASPNETCORE_ENVIRONMENT=Development -e Api__BaseUrl=http://host.docker.internal:5260 web.apphost:latest",
        "launchBrowser": true,
        "applicationUrl": "http://localhost:8080"
      }
    }
  }
