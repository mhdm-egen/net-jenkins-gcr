def NEXUS_DOCKER_AUTHENTICATED = false
def CONTAINER_TAG = "latest"

pipeline {
    parameters {
        string(name: 'BUILD_CONTAINER_IMAGE', defaultValue: 'netsdk10:latest', description: 'Image for the build container')
        string(name: 'BUILD_CONTAINER_ARGS', defaultValue: '-v /tmp/nuget:/tmp/nuget -e DOTNET_CLI_TELEMETRY_OPTOUT=1 --net=cicd-net -u root -v /var/run/docker.sock:/var/run/docker.sock -v /tmp/trivy-cache:/root/.cache/trivy --group-add 0', description: 'Arguments for the build container')
        string(name: 'DOCKER_BUILD_FILE', defaultValue: '', description: 'Optional Dockerfile override (a path within the app repo). Blank = use the built-in copy-only runtime Dockerfile generated by this job. Build context is the per-app publish output, not source — no in-container compile.')
        string(name: 'CONTAINER_NAME', defaultValue: '', description: 'Optional single-container override. Normally blank: the container list comes from build-info.json (the cicd-build container manifest).')
        string(name: 'GIT_CREDENTIALS_ID', defaultValue: '', description: 'Jenkins credentials ID for cloning a private app repo (leave blank for public/anonymous access)')
        string(name: 'NEXUS_DOCKER_HOST', defaultValue: 'nexus:8082', description: 'Nexus docker registry host:port (port determines the target hosted repo via the Nexus connector)')
        string(name: 'NEXUS_DOCKER_CREDENTIAL_ID', defaultValue: 'rhythm-docker', description: 'Jenkins credential id (Username/Password) for the Nexus docker registry')
        string(name: 'NEXUS_DOCKER_USER', defaultValue: 'admin', description: 'Nexus docker registry username (for Jenkins credentials)')
        string(name: 'NEXUS_DOCKER_PROTOCOL', defaultValue: 'http://', description: 'Nexus communications protocol (http or https)')
        string(name: 'TRIVY_VERSION', defaultValue: 'v0.55.0', description: 'Trivy release tag used to scan the built container image (fallback download if not baked into the build image)')
        choice(name: 'FAIL_ON_SEVERITY', choices: ['none', 'high', 'critical'], description: 'Fail the publish when the built image has OS/library vulnerabilities at this severity (or worse). Default: report only, do not fail.')
        string(name: 'SBOM_NEXUS_REPO_URL', defaultValue: 'http://nexus:8081/repository/sboms/', description: 'Nexus raw (hosted) repo URL where the per-image scan report is uploaded')
        string(name: 'SBOM_NEXUS_CREDENTIAL_ID', defaultValue: 'nexus-sbom', description: 'Jenkins credential id (Username/Password) for the Nexus REST API (image-scan upload)')
        string(name: 'SOURCE_BUILD_JOB', defaultValue: 'cicd-scan', description: 'Name of the upstream job whose build-info.json will be pulled in (the scan job, which re-archives build-info.json from cicd-build)')
        string(name: 'SOURCE_BUILD_NUMBER', defaultValue: '', description: 'Specific upstream build number to publish. Leave empty for the last successful build.')
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        // Repo-agnostic: we clone the app repo ourselves (from build-info.json's gitUrl,
        // pinned to gitCommitHash) instead of relying on a pipeline-repo checkout.
        skipDefaultCheckout(true)
    }

    agent {
        docker {
            image "${params.BUILD_CONTAINER_IMAGE}"
            args "${params.BUILD_CONTAINER_ARGS}"
            reuseNode true
        }
    }

    stages {
        stage ('Init') {
            steps {
                script {
                    sh "git config --global --add safe.directory '*'"

                    println "Initializing publish to Nexus docker"
                    println "Using build container image: ${params.BUILD_CONTAINER_IMAGE}"
                    println "Build container arguments: ${params.BUILD_CONTAINER_ARGS}"
                    println "Build #${BUILD_NUMBER} started at ${new Date().format("yyyy-MM-dd HH:mm:ss")}"
                }
            }
        }

        stage ('Resolve build') {
            steps {
                script {
                    def srcBuild = params.SOURCE_BUILD_NUMBER?.trim()
                    def selector = srcBuild
                        ? [$class: 'SpecificBuildSelector', buildNumber: srcBuild]
                        : [$class: 'StatusBuildSelector']
                    def srcLabel = srcBuild ? "build #${srcBuild}" : "lastSuccessful()"
                    println "Fetching build-info.json from ${params.SOURCE_BUILD_JOB} (${srcLabel})"

                    // Copied into _meta/ so the workspace root stays free for the app-repo clone.
                    copyArtifacts(
                        projectName: params.SOURCE_BUILD_JOB,
                        selector: selector,
                        filter: 'build-info.json',
                        target: '_meta',
                        fingerprintArtifacts: true
                    )

                    def info = readJSON file: '_meta/build-info.json'

                    PACKAGE_VERSION  = info.packageVersion
                    INFO_VERSION     = info.informationalVersion
                    ASSEMBLY_VERSION = info.assemblyVersion
                    FILE_VERSION     = info.fileVersion
                    GIT_COMMIT_HASH  = info.gitCommitHash
                    GIT_COMMIT_SHORT = info.gitCommitShort
                    SOURCE_BUILD_NUM = info.buildNumber
                    GIT_URL          = info.gitUrl
                    GIT_BRANCH       = info.gitBranch

                    // Container manifest from cicd-build. Empty for library-only builds.
                    // An explicit CONTAINER_NAME override (rare) replaces the manifest with a
                    // single entry whose project = BUILD_FILE.
                    CONTAINERS = info.containers ?: []
                    if (params.CONTAINER_NAME?.trim()) {
                        CONTAINERS = [[project: info.buildFile, containerName: params.CONTAINER_NAME.trim(), assembly: params.CONTAINER_NAME.trim()]]
                    }

                    println "Resolved upstream build: #${SOURCE_BUILD_NUM}"
                    println "  packageVersion : ${PACKAGE_VERSION}"
                    println "  infoVersion    : ${INFO_VERSION}"
                    println "  gitUrl         : ${GIT_URL}"
                    println "  gitBranch      : ${GIT_BRANCH}"
                    println "  gitCommitHash  : ${GIT_COMMIT_HASH}"
                    println "  gitCommitShort : ${GIT_COMMIT_SHORT}"
                    println "  containers     : ${CONTAINERS.collect { it.containerName }} (${CONTAINERS.size()})"

                    currentBuild.description = "publish ${params.SOURCE_BUILD_JOB} #${SOURCE_BUILD_NUM} (${PACKAGE_VERSION}) — ${CONTAINERS.size()} container(s)"
                }
            }
        }

        stage ('Checkout source') {
            // Library-only builds have no source to publish — skip the clone entirely.
            when { expression { return !CONTAINERS.isEmpty() } }
            steps {
                script {
                    if (!GIT_URL?.trim()) {
                        error "build-info.json has no gitUrl — cannot fetch the source to publish. Re-run cicd-build to produce a gitUrl."
                    }
                    // Clone the exact repo + commit cicd-build built (repo-agnostic; immune to the
                    // pipeline repo's HEAD advancing). _meta/ (untracked) survives the checkout.
                    def remote = [url: GIT_URL.trim()]
                    if (params.GIT_CREDENTIALS_ID?.trim()) {
                        remote.credentialsId = params.GIT_CREDENTIALS_ID.trim()
                    }
                    println "Cloning ${GIT_URL} @ ${GIT_COMMIT_HASH}"
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: GIT_COMMIT_HASH]],
                        userRemoteConfigs: [remote]
                    ])
                    sh "git config --global --add safe.directory '*'"
                }
            }
        }

        stage('Build and push containers') {
            // Skip cleanly for library-only builds (no containerizable projects upstream).
            when { expression { return !CONTAINERS.isEmpty() } }
            steps {
                withCredentials([usernamePassword(credentialsId: "${params.NEXUS_DOCKER_CREDENTIAL_ID}", usernameVariable: 'NEXUS_DOCKER_USER', passwordVariable: 'NEXUS_DOCKER_PASS')]) {
                    script {
                        // One docker login for the whole batch.
                        sh """
                            set -e
                            echo "Logging in to Nexus docker registry ${params.NEXUS_DOCKER_HOST}"
                            echo "\$NEXUS_DOCKER_PASS" | docker login ${params.NEXUS_DOCKER_PROTOCOL}${params.NEXUS_DOCKER_HOST} -u "\$NEXUS_DOCKER_USER" --password-stdin
                        """
                        NEXUS_DOCKER_AUTHENTICATED = true

                        // Resolve the Dockerfile: an explicit override path (within the cloned app
                        // repo) or the built-in copy-only runtime template written here. Inlining it
                        // means the job needs no pipeline-repo tree in the workspace (repo-agnostic).
                        // This is the single source of truth for the CI runtime image. The literal
                        // ''' block leaves $APP_UID / ${ENTRY_ASSEMBLY} / $APP_ENTRY_DLL for Docker.
                        def dockerfile = params.DOCKER_BUILD_FILE?.trim()
                        if (!dockerfile) {
                            dockerfile = 'runtime.Dockerfile'
                            writeFile file: dockerfile, text: '''# Generated by cicd-publish-nexus-docker — copy-only runtime image (no in-container compile).
FROM mcr.microsoft.com/dotnet/aspnet:10.0
ARG ENTRY_ASSEMBLY
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY . ./
USER $APP_UID
EXPOSE 8080
ENV ASPNETCORE_HTTP_PORTS=8080
ENV APP_ENTRY_DLL=${ENTRY_ASSEMBLY}.dll
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD curl -fsS http://localhost:8080/alive || exit 1
ENTRYPOINT ["sh", "-c", "exec dotnet \\"$APP_ENTRY_DLL\\""]
'''
                        }
                        println "Using runtime Dockerfile: ${dockerfile}"

                        // Resolve the Trivy binary once (baked into the build image; download fallback).
                        TRIVY_BIN = sh(returnStdout: true, script: """
                            set -e
                            if command -v trivy >/dev/null 2>&1; then
                                command -v trivy
                            else
                                mkdir -p ${env.WORKSPACE}/.trivy
                                BIN=${env.WORKSPACE}/.trivy/trivy
                                if [ ! -x "\$BIN" ]; then
                                    V=\$(echo "${params.TRIVY_VERSION}" | sed 's/^v//')
                                    curl -fsSL "https://github.com/aquasecurity/trivy/releases/download/${params.TRIVY_VERSION}/trivy_\${V}_Linux-64bit.tar.gz" | tar -xz -C ${env.WORKSPACE}/.trivy/ trivy >&2
                                    chmod +x "\$BIN"
                                fi
                                echo "\$BIN"
                            fi
                        """).trim()
                        // FAIL_ON_SEVERITY → Trivy --severity set used to gate the push.
                        def gateSeverity = [high: 'HIGH,CRITICAL', critical: 'CRITICAL'][params.FAIL_ON_SEVERITY]

                        CONTAINERS.each { c ->
                            def project  = c.project
                            def name     = c.containerName
                            def assembly = c.assembly ?: name
                            def outDir   = "publish/${name}"
                            def repo     = "${params.NEXUS_DOCKER_HOST}/${name}"
                            // Same four tags as before: floating, per-build, per-commit, and a
                            // combined immutable build+commit handle.
                            def tags = [
                                "${repo}:${CONTAINER_TAG}",
                                "${repo}:ci-${SOURCE_BUILD_NUM}",
                                "${repo}:${GIT_COMMIT_SHORT}",
                                "${repo}:${SOURCE_BUILD_NUM}-${GIT_COMMIT_SHORT}"
                            ]

                            println "Container '${name}': publish ${project} -> ${outDir}, image runs dotnet ${assembly}.dll"
                            println "Nexus tags: ${tags.join(', ')}"

                            // 1) Publish the app on the agent (NOT inside the container).
                            // 2) Build the copy-only runtime image from that publish output.
                            sh """
                                set -e
                                rm -rf ${outDir}
                                dotnet publish '${project}' -c Release -o ${outDir} \\
                                    /p:UseAppHost=false \\
                                    /p:Version=${PACKAGE_VERSION} \\
                                    /p:AssemblyVersion=${ASSEMBLY_VERSION} \\
                                    /p:FileVersion=${FILE_VERSION} \\
                                    /p:InformationalVersion="${INFO_VERSION}"

                                docker build --file ${dockerfile} \\
                                    --build-arg ENTRY_ASSEMBLY='${assembly}' \\
                                    -t ${name}:${CONTAINER_TAG} ${outDir}
                            """

                            // 3) Scan the built IMAGE for OS + library CVEs (the base image is
                            //    not covered by the dependency SBOM). Always produce a report;
                            //    gate the push only when FAIL_ON_SEVERITY is set.
                            sh """
                                set -e
                                mkdir -p _meta
                                echo "Trivy image scan: ${name}:${CONTAINER_TAG}"
                                ${TRIVY_BIN} image --scanners vuln --format cyclonedx \\
                                    --output _meta/image-${name}.json ${name}:${CONTAINER_TAG}
                            """
                            if (gateSeverity) {
                                def rc = sh(returnStatus: true,
                                    script: "${TRIVY_BIN} image --scanners vuln --exit-code 1 --severity ${gateSeverity} --quiet ${name}:${CONTAINER_TAG}")
                                if (rc != 0) {
                                    error "Image '${name}' has vulnerabilities at severity '${params.FAIL_ON_SEVERITY}' or higher — failing publish (FAIL_ON_SEVERITY=${params.FAIL_ON_SEVERITY})."
                                }
                            }

                            // 4) Tag + push the four tags.
                            sh """
                                set -e
                                docker tag ${name}:${CONTAINER_TAG} ${tags[0]}
                                docker tag ${name}:${CONTAINER_TAG} ${tags[1]}
                                docker tag ${name}:${CONTAINER_TAG} ${tags[2]}
                                docker tag ${name}:${CONTAINER_TAG} ${tags[3]}

                                docker push ${tags[0]}
                                docker push ${tags[1]}
                                docker push ${tags[2]}
                                docker push ${tags[3]}
                            """
                        }
                    }
                }
            }
        }

        stage('Upload image scans') {
            when { expression { return !CONTAINERS.isEmpty() } }
            steps {
                withCredentials([usernamePassword(credentialsId: "${params.SBOM_NEXUS_CREDENTIAL_ID}", usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
                    script {
                        // Upload each per-image Trivy report to the Nexus SBOM raw repo at
                        //   <SBOM_NEXUS_REPO_URL>sbom/<PACKAGE_VERSION>/image-<name>.json
                        CONTAINERS.each { c ->
                            def name = c.containerName
                            sh """
                                set -e
                                base="${params.SBOM_NEXUS_REPO_URL}"
                                base="\${base%/}"
                                target="\$base/sbom/${PACKAGE_VERSION}/image-${name}.json"
                                if [ -f "_meta/image-${name}.json" ]; then
                                    echo "  PUT \$target"
                                    curl -fsS --user "\$NEXUS_USER:\$NEXUS_PASS" --upload-file "_meta/image-${name}.json" "\$target"
                                    echo
                                else
                                    echo "WARN: _meta/image-${name}.json not present — skipping upload."
                                fi
                            """
                        }
                    }
                }
            }
        }

        stage('Library-only (no container)') {
            when { expression { return CONTAINERS.isEmpty() } }
            steps {
                echo "Upstream build ${params.SOURCE_BUILD_JOB} #${SOURCE_BUILD_NUM} has no containerizable projects — nothing to publish to the docker registry. Succeeding."
            }
        }

        stage ('Archive Build Info') {
            steps {
                archiveArtifacts artifacts: '_meta/build-info.json,_meta/image-*.json', fingerprint: true, onlyIfSuccessful: true, allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            script {
                if (NEXUS_DOCKER_AUTHENTICATED) {
                    println "Cleaning up Nexus docker authentication"
                    sh "docker logout ${params.NEXUS_DOCKER_PROTOCOL}${params.NEXUS_DOCKER_HOST} || true"
                }
            }
            echo "Post-publish cleanup completed"
        }
        success {
            echo "Build #${BUILD_NUMBER} published ${CONTAINERS.size()} container(s) ${CONTAINERS.collect { it.containerName }} at ci-${SOURCE_BUILD_NUM} to Nexus (from ${params.SOURCE_BUILD_JOB} #${SOURCE_BUILD_NUM})"
        }
        failure {
            echo "Build #${BUILD_NUMBER} failed at stage: ${env.STAGE_NAME}"
        }
    }
}
