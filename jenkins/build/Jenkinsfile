pipeline {
    parameters {
        string(name: 'GIT_URL', defaultValue: '', description: 'Git repository URL to build (required). The Jenkinsfile clones this itself — the job no longer decides which repo to build.')
        string(name: 'GIT_BRANCH', defaultValue: 'main', description: 'Branch, tag, or ref to build')
        string(name: 'GIT_CREDENTIALS_ID', defaultValue: '', description: 'Jenkins credentials ID for cloning a private repo (leave blank for public/anonymous access)')
        string(name: 'BUILD_CONTAINER_IMAGE', defaultValue: 'netsdk10:latest', description: 'Image for the build container')
        string(name: 'BUILD_CONTAINER_ARGS', defaultValue: '-v /tmp/nuget:/tmp/nuget -e DOTNET_CLI_TELEMETRY_OPTOUT=1 --net=cicd-net -u root -v /var/run/docker.sock:/var/run/docker.sock -v /tmp/trivy-cache:/root/.cache/trivy --group-add 0', description: 'Arguments for the build container')
        string(name: 'BUILD_FILE', defaultValue: 'src/app/cicd.sln', description: 'File to build (sln or csproj)')
        string(name: 'BASE_VER', defaultValue: '1.0.0', description: 'Base version (Major.Minor.Patch) used to derive PackageVersion / FileVersion / AssemblyVersion / InformationalVersion in build-info.json')
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        // We clone GIT_URL ourselves in the Checkout stage; don't let Jenkins
        // implicitly check out the job's own SCM into the build workspace.
        skipDefaultCheckout(true)
    }

    agent {
        docker {
            image "${params.BUILD_CONTAINER_IMAGE}"
            args "${params.BUILD_CONTAINER_ARGS}"
            reuseNode true
        }
    }

    stages {
        stage ('Checkout') {
            steps {
                script {
                    if (!params.GIT_URL?.trim()) {
                        error "GIT_URL parameter is required — it is the repository this build clones and builds."
                    }

                    // Clone the requested repo/branch into the (empty) workspace. The
                    // caller controls the repo via GIT_URL; the job config no longer does.
                    def remote = [url: params.GIT_URL.trim()]
                    if (params.GIT_CREDENTIALS_ID?.trim()) {
                        remote.credentialsId = params.GIT_CREDENTIALS_ID.trim()
                    }

                    println "Cloning ${params.GIT_URL} @ ${params.GIT_BRANCH}"
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: params.GIT_BRANCH]],
                        userRemoteConfigs: [remote]
                    ])
                }
            }
        }

        stage ('Init') {
            steps {
                script {
                    sh "git config --global --add safe.directory '*'"

                    println "Initializing build for ${params.BUILD_FILE}"
                    println "Using build container image: ${params.BUILD_CONTAINER_IMAGE}"
                    println "Build container arguments: ${params.BUILD_CONTAINER_ARGS}"
                    println "Build #${BUILD_NUMBER} started at ${new Date().format("yyyy-MM-dd HH:mm:ss")}"

                    GIT_COMMIT_HASH = sh(script: "git log -n 1 --pretty=format:%H", returnStdout: true).trim()
                    GIT_COMMIT_SHORT = GIT_COMMIT_HASH.take(7)
                    println "Git commit hash: ${GIT_COMMIT_HASH}"
                    println "Git commit short: ${GIT_COMMIT_SHORT}"

                    PACKAGE_VERSION  = "${params.BASE_VER}-ci.${env.BUILD_NUMBER}.g${GIT_COMMIT_SHORT}"
                    FILE_VERSION     = "${params.BASE_VER}.${env.BUILD_NUMBER}"
                    ASSEMBLY_VERSION = "${params.BASE_VER}.0"
                    INFO_VERSION     = "${PACKAGE_VERSION}+${GIT_COMMIT_SHORT}"

                    println "PackageVersion:  ${PACKAGE_VERSION}"
                    println "AssemblyVersion: ${ASSEMBLY_VERSION}"
                    println "FileVersion:     ${FILE_VERSION}"
                    println "InfoVersion:     ${INFO_VERSION}"
                }
            }
        }

        stage ('Restore') {
            steps {
                sh "dotnet restore ${params.BUILD_FILE}"
            }
        }

        stage ('Build') {
            steps {
                sh "dotnet build --no-restore -c Release ${params.BUILD_FILE}"
            }
        }

        stage ('Test') {
            steps {
                //  sh "dotnet test --no-restore --no-build -c Release ${params.BUILD_FILE} --logger trx"
                echo "Skipping tests for now"
            }
        }

        stage ('Discover Containers') {
            steps {
                script {
                    // Determine which projects opt in to being containerized
                    // (<Containerizable>true</Containerizable>, see src/app/Directory.Build.props).
                    // For each opted-in project record { project, containerName, assembly }.
                    // A library-only solution yields an empty list and produces no container
                    // downstream — the cicd-publish-nexus-docker job self-skips on [].
                    CONTAINERS = []
                    def buildFile = params.BUILD_FILE.trim()
                    def isSln = buildFile.toLowerCase().endsWith('.sln')

                    // Enumerate candidate projects: every .csproj in the solution, or the
                    // single project when BUILD_FILE is itself a .csproj.
                    def projects = []
                    if (isSln) {
                        def slnDir = buildFile.contains('/') ? buildFile.substring(0, buildFile.lastIndexOf('/')) : '.'
                        def listed = sh(script: "dotnet sln ${buildFile} list", returnStdout: true).trim()
                        listed.readLines().each { line ->
                            def p = line.trim().replace('\\', '/')
                            if (p.toLowerCase().endsWith('.csproj')) {
                                // `dotnet sln list` prints paths relative to the .sln directory.
                                projects << (p.startsWith('/') ? p : "${slnDir}/${p}")
                            }
                        }
                    } else {
                        projects << buildFile
                    }

                    // Query the opt-in properties without building (-getProperty is the
                    // build-less evaluator). Multiple -getProperty flags emit JSON:
                    //   {"Properties":{"Containerizable":"true","CiContainerName":"…","AssemblyName":"…"}}
                    projects.each { proj ->
                        def raw = sh(
                            script: "dotnet msbuild '${proj}' -getProperty:Containerizable -getProperty:CiContainerName -getProperty:AssemblyName -nologo",
                            returnStdout: true).trim()
                        def props = readJSON(text: raw).Properties ?: [:]
                        if ((props.Containerizable ?: '').toString().equalsIgnoreCase('true')) {
                            def assembly = (props.AssemblyName ?: '').toString().trim()
                            def name = (props.CiContainerName ?: '').toString().trim()
                            if (!name) name = assembly.toLowerCase()
                            CONTAINERS << [project: proj, containerName: name, assembly: assembly]
                            println "Containerizable: ${proj} -> ${name} (dotnet ${assembly}.dll)"
                        }
                    }

                    if (CONTAINERS.isEmpty()) {
                        println "No containerizable projects (library-only build)."
                    }
                }
            }
        }

        stage ('Archive Build Info') {
            steps {
                script {
                    writeJSON file: 'build-info.json', json: [
                        packageVersion:       PACKAGE_VERSION,
                        fileVersion:          FILE_VERSION,
                        assemblyVersion:      ASSEMBLY_VERSION,
                        informationalVersion: INFO_VERSION,
                        gitCommitHash:        GIT_COMMIT_HASH,
                        gitCommitShort:       GIT_COMMIT_SHORT,
                        buildNumber:          env.BUILD_NUMBER,
                        packVer:              params.BASE_VER,
                        buildFile:            params.BUILD_FILE,
                        gitUrl:               params.GIT_URL,
                        gitBranch:            params.GIT_BRANCH,
                        buildTimestamp:       new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'", TimeZone.getTimeZone('UTC')),
                        // Container manifest discovered above; [] for library-only builds.
                        // Drives cicd-publish-nexus-docker (which self-skips on []).
                        containers:           CONTAINERS
                    ], pretty: 2

                    sh "cat build-info.json"

                    // Archive build-info.json (incl. the container manifest). Security scanning
                    // (SBOM + vuln + Trivy VEX) is now the downstream cicd-scan job's job; it
                    // pulls this build-info.json and produces/uploads the SBOMs.
                    archiveArtifacts(
                        artifacts: 'build-info.json',
                        fingerprint: true,
                        onlyIfSuccessful: true)

                    currentBuild.description = "${PACKAGE_VERSION} (${GIT_COMMIT_SHORT})"
                }
            }
        }
    }

    post {
        success {
            echo "Build #${BUILD_NUMBER} compiled successfully (PackageVersion ${PACKAGE_VERSION})"
        }
        failure {
            echo "Build #${BUILD_NUMBER} failed at stage: ${env.STAGE_NAME}"
        }
    }
}
